# BigQuery Data Agent
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID
GCP_LOCATION=global
DATA_AGENT_ID=YOUR_DATA_AGENT_ID

# Google Cloud Project / Gemini Enterprise
GCP_ENGINE_ID=YOUR_DISCOVERY_ENGINE_ID
GCP_REGION=us-central1
# GCP_LOCATION above is used for the Discovery Engine location (usually "us")
# Separate DISCOVERY_LOCATION if your engine lives in a different region:
DISCOVERY_LOCATION=us

# Entra ID (Azure AD) OAuth
OAUTH_TENANT_ID=YOUR_ENTRA_TENANT_ID
OAUTH_CLIENT_ID=YOUR_ENTRA_CLIENT_ID
OAUTH_CLIENT_SECRET=YOUR_ENTRA_CLIENT_SECRET
# Scopes for BigQuery access via delegated OAuth
# OAUTH_SCOPES=https://www.googleapis.com/auth/bigquery https://www.googleapis.com/auth/cloud-platform openid offline_access

# Logging (DEBUG for verbose OAuth flow tracing, INFO for normal operation)
LOG_LEVEL=INFO

# Workforce Identity Federation — GCP pool/provider that trusts the Entra ID app.
# The proxy exchanges the Entra token for a Google token via WIF STS before
# calling the BigQuery Data Agent.
WIF_POOL=YOUR_WIF_POOL
WIF_PROVIDER=YOUR_WIF_PROVIDER

# Agent identity
AGENT_NAME=bq-dataagent-a2a
AGENT_DESCRIPTION=Query your BigQuery data in plain English with per-user identity propagation.

# Cloud Run Service URL (set after first deploy, used by register_a2a_agent.py)
AGENT_URL=https://YOUR_SERVICE-YOUR_HASH-uc.a.run.app
